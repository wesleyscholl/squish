[29.089, "o", "     16K BF16 weights  compress \u001b[1m\u001b[95m 11.1 ms\u001b[0m  decompress \u001b[1m\u001b[96m 12.9 ms\u001b[0m  \u001b[2mlossless\u001b[0m\r\n"]
